#3.
hour = int(input("Gio xuat phat: "))
minute = int(input("Phut xuat phat: "))
start = hour*3600 + minute*60
run = 8*60 + 15 + 3*(7*60 + 12) + 8*60 + 15
total = start + run
h = total//3600
m = (total%3600)/60
print("Ve nha an sang vao ", h, "gio ", m, "phut.")
